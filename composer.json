{
  "name": "lunar-bedrock/pmmpcompat",
  "description": "PocketMine-MP compatibility facade for Dragonfly-backed Bedrock servers.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "bin": [
    "bin/pmmpcompat-runtime.php"
  ],
  "autoload": {
    "psr-4": {
      "pocketmine\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PmmpCompat\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
